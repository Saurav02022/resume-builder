# --- App secrets (deployment / operators only; end users never see these) ---

# Gemini — one key per deployed product (or per environment)
NEXT_PUBLIC_GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Google OAuth — one OAuth 2.0 "Web application" client per deployment (staging + prod each need
# their own client + redirect URIs). Every end user signs in with their own Google account; you
# do not create credentials per customer.
# Console: https://console.cloud.google.com/apis/credentials — enable Google Drive API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# Encrypts the server session cookie that holds each user’s OAuth tokens (after they click
# "Continue with Google"). Min 32 characters; rotate if leaked.
GOOGLE_OAUTH_COOKIE_PASSWORD=
